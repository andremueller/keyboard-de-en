// German (US Mix) Keyboard Layout
// Based on US layout with German umlauts accessible via Alt key
// Level 1: normal, Level 2: Shift, Level 3: Alt, Level 4: Shift+Alt

default partial alphanumeric_keys
xkb_symbols "basic" {

    include "us(basic)"

    name[Group1]="German (US Mix)";

    // a -> ä / Ä
    key <AC01> { [ a, A, adiaeresis, Adiaeresis ] };
    // s -> ß (no uppercase for ß in traditional usage)
    key <AC02> { [ s, S, ssharp, ssharp ] };
    // u -> ü / Ü
    key <AD07> { [ u, U, udiaeresis, Udiaeresis ] };
    // o -> ö / Ö
    key <AD09> { [ o, O, odiaeresis, Odiaeresis ] };

    // Use Alt (not AltGr) as level3 modifier
    include "level3(alt_switch)"
};
